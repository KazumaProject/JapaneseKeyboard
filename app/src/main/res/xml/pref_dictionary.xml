<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/system_user_dictionary">

        <Preference
            android:key="system_user_dictionary_builder_preference"
            android:title="@string/system_user_dictionary_builder_title"
            app:summary="@string/system_user_dictionary_builder_summary" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/external_dictionary_settings_title">

        <Preference
            android:key="external_dictionary_settings_preference"
            android:title="@string/external_dictionary_settings_title"
            app:summary="@string/external_dictionary_settings_summary" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="N-gram">

        <Preference
            android:key="n_gram_rule_preference"
            android:title="@string/n_gram_rule_preference_title"
            app:summary="@string/n_gram_rule_preference_summary" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/candidate_order_override_fragment_title">

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="candidate_order_override_enable_preference"
            android:summaryOff="@string/candidate_order_override_enable_summary_off"
            android:summaryOn="@string/candidate_order_override_enable_summary_on"
            android:title="@string/candidate_order_override_enable_title"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="candidate_order_override_preference"
            android:title="@string/candidate_order_override_preference_title"
            app:iconSpaceReserved="false"
            app:summary="@string/candidate_order_override_preference_summary" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/category_ng_word_title"
        app:summary="@string/category_ng_word_summary">

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="ng_word_enable_preference" />

        <Preference
            android:icon="@drawable/outline_border_color_24"
            android:key="ng_word_preference"
            android:title="@string/ng_word_list_title"
            app:summary="@string/ng_word_list_summary" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/category_learning_dictionary_title">
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="learn_dictionary_preference"
            android:summaryOff="@string/learn_dictionary_summary_off"
            android:summaryOn="@string/learn_dictionary_summary_on"
            android:title="@string/learn_dictionary_title" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="incognito_mode_detection_preference"
            android:summaryOff="@string/incognito_mode_detection_summary_off"
            android:summaryOn="@string/incognito_mode_detection_summary_on"
            android:title="@string/incognito_mode_detection_title"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="show_learned_candidates_in_incognito_preference"
            android:summaryOff="@string/show_learned_candidates_in_incognito_summary_off"
            android:summaryOn="@string/show_learned_candidates_in_incognito_summary_on"
            android:title="@string/show_learned_candidates_in_incognito_title"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:dependency="learn_dictionary_preference"
            android:key="learn_first_candidate_dictionary_preference"
            android:title="@string/learn_dictionary_preference_title"
            app:defaultValue="false"
            app:summary="@string/learn_dictionary_preference_summary" />

        <SwitchPreferenceCompat
            android:dependency="learn_dictionary_preference"
            android:key="enable_prediction_search_learn_dictionary_preference"
            android:title="@string/enable_prediction_search_learn_dictionary_preference_titile"
            app:defaultValue="false"
            app:summary="@string/enable_prediction_search_learn_dictionary_preference_summary" />

        <SeekBarPreference
            android:defaultValue="4"
            android:dependency="enable_prediction_search_learn_dictionary_preference"
            android:key="learn_prediction_preference"
            android:max="8"
            android:title="@string/user_dictionary_prefix_match_title"
            app:min="1"
            app:showSeekBarValue="true" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/category_user_dictionary_title">
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="user_dictionary_preference"
            android:summaryOff="@string/user_dictionary_summary_off"
            android:summaryOn="@string/user_dictionary_summary_on"
            android:title="@string/user_dictionary_title" />

        <SeekBarPreference
            android:defaultValue="2"
            android:dependency="user_dictionary_preference"
            android:key="user_dictionary_prefix_match_number"
            android:max="8"
            android:title="@string/user_dictionary_prefix_match_title"
            app:min="2"
            app:showSeekBarValue="true" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/user_template_title">
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="user_template_preference"
            android:summaryOff="@string/user_template_summary_off"
            android:summaryOn="@string/user_template_summary_on"
            android:title="@string/user_template_title" />
    </PreferenceCategory>

</androidx.preference.PreferenceScreen>
