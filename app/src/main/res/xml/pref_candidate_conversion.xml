<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory android:title="@string/setting_category_candidate_bar_title">

        <Preference
            android:icon="@drawable/outline_border_color_24"
            android:key="candidate_view_height_setting_fragment_preference"
            android:title="@string/candidate_height_portrait_preference_title"
            app:summary="@string/candidate_height_preference_sumary" />

        <Preference
            android:icon="@drawable/outline_border_color_24"
            android:key="candidate_view_height_landscape_setting_fragment_preference"
            android:title="@string/candidate_height_landscape_preference_title"
            app:summary="@string/candidate_height_preference_sumary" />

        <ListPreference
            android:defaultValue="1"
            android:dialogTitle="@string/preference_dialog_title_num_columns_conversion"
            android:entries="@array/candidate_column_entries"
            android:entryValues="@array/candidate_column_values"
            android:key="candidate_column_preference"
            android:summary="@string/preference_summary_num_column_conversion"
            android:title="@string/preference_title_num_columns_conversion" />

        <ListPreference
            android:defaultValue="1"
            android:dialogTitle="@string/preference_dialog_title_num_columns_conversion"
            android:entries="@array/candidate_column_entries_landscape"
            android:entryValues="@array/candidate_column_values_landscape"
            android:key="candidate_column_landscape_preference"
            android:summary="@string/preference_summary_num_column_conversion"
            android:title="@string/preference_title_num_columns_conversion_landscape" />

        <SwitchPreferenceCompat
            android:key="candidate_tab_visibility_preference"
            android:title="@string/candidate_tab"
            app:defaultValue="false"
            app:summary="@string/candidate_tab_summary" />

        <Preference
            android:dependency="candidate_tab_visibility_preference"
            android:key="candidate_tab_order_preference"
            android:title="@string/candidate_tab_order_preference_title"
            app:summary="@string/candidate_tab_order_preference_summary" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="hide_candidate_password_preference"
            android:summaryOff="@string/hide_candidate_password_summary_off"
            android:summaryOn="@string/hide_candidate_password_summary_on"
            android:title="@string/hide_candidate_password_title" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/conversion_preference_title">

        <SeekBarPreference
            android:defaultValue="4"
            android:key="n_best_preference"
            android:max="16"
            android:summary="@string/n_best_preference_summary"
            android:title="N-Best"
            app:min="2"
            app:showSeekBarValue="true" />

        <SwitchPreferenceCompat
            android:key="enable_mozc_compatible_conversion_preference"
            android:title="@string/pref_mozc_compatible_conversion_title"
            android:summary="@string/pref_mozc_compatible_conversion_summary"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="conversion_bunsetsu_separation_preference"
            android:title="@string/conversion_separation_title"
            app:summary="@string/conversion_separation_summary" />

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:dependency="conversion_bunsetsu_separation_preference"
            android:key="conversion_bunsetsu_cursor_move_preference"
            android:title="@string/conversion_bunsetsu_cursor_move_title"
            app:summary="@string/conversion_bunsetsu_cursor_move_summary" />

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="reconversion_preference"
            android:title="@string/reconversion_preference_title"
            app:summary="@string/reconversion_preference_summary" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="henkan_delete_key_action_preference"
            android:summaryOff="@string/henkan_delete_key_action_summary_off"
            android:summaryOn="@string/henkan_delete_key_action_summary_on"
            android:title="@string/henkan_delete_key_action_title" />

        <SwitchPreferenceCompat
            android:key="conversion_candidates_romaji_enable_preference"
            android:title="@string/conversion_candidates_romaji_enable_preference_title"
            app:defaultValue="false"
            app:summary="@string/conversion_candidates_romaji_enable_preference_summary" />

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="live_conversion_preference"
            android:summaryOff="@string/live_conversion_summary_off"
            android:summaryOn="@string/live_conversion_summary_on"
            android:title="@string/live_conversion_title" />

        <SeekBarPreference
            android:defaultValue="1"
            android:dependency="live_conversion_preference"
            android:key="live_conversion_start_length_preference"
            android:max="10"
            android:summary="@string/live_conversion_start_length_summary"
            android:title="@string/live_conversion_start_length_title"
            app:min="1"
            app:showSeekBarValue="true" />

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:dependency="live_conversion_preference"
            android:key="live_conversion_candidate_yomi_preference"
            android:summaryOff="@string/live_conversion_candidate_yomi_summary_off"
            android:summaryOn="@string/live_conversion_candidate_yomi_summary_on"
            android:title="@string/live_conversion_candidate_yomi_title" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/typo_correction_title">

        <SwitchPreferenceCompat
            android:key="enable_typo_correction_japanese_flick_keyboard_preference"
            android:title="@string/enable_typo_correction_japanese_flick_keyboard_preference_title"
            app:defaultValue="false"
            app:summary="@string/enable_typo_correction_japanese_flick_keyboard_preference_sumary" />

        <SeekBarPreference
            android:key="enable_typo_correction_japanese_flick_keyboard_offset_score_preference"
            android:max="5000"
            android:title="@string/enable_typo_correction_japanese_flick_keyboard_offset_score_preference_tittle"
            app:defaultValue="3000"
            app:min="0"
            app:seekBarIncrement="10"
            app:showSeekBarValue="true"
            app:summary="@string/enable_typo_correction_japanese_flick_keyboard_offset_score_preference_summary" />

        <SwitchPreferenceCompat
            android:key="enable_typo_correction_qwerty_english_keyboard_preference"
            android:title="@string/enable_typo_correction_qwerty_english_keyboard_preference_title"
            app:defaultValue="false"
            app:summary="@string/enable_typo_correction_qwerty_english_keyboard_preference_summary" />

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="omission_search_preference"
            android:summaryOff="@string/omission_search_summary_off"
            android:summaryOn="@string/omission_search_summary_on"
            android:title="@string/omission_search_title" />

        <SeekBarPreference
            android:key="omission_search_preference_offset_score_preference"
            android:max="5000"
            android:title="@string/omission_search_preference_offset_score_preference_title"
            app:defaultValue="1900"
            app:min="0"
            app:seekBarIncrement="10"
            app:showSeekBarValue="true"
            app:summary="@string/omission_search_preference_offset_score_preference_summary" />

    </PreferenceCategory>

</PreferenceScreen>
