<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/keyboard_bg"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/gemma_image_action_title"
            android:textColor="@color/keyboard_icon_color"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/button_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/cancel_string"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_gemma_panel_close"
            android:tint="@color/keyboard_icon_color" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/image_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="4dp"
                    android:text="@string/gemma_image_source_title"
                    android:textColor="@color/keyboard_icon_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/button_clipboard_image"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:minHeight="0dp"
                        android:text="@string/gemma_use_clipboard_image"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/button_device_image"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:minHeight="0dp"
                        android:text="@string/gemma_use_device_image"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/image_selection_group"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/image_preview"
                        android:layout_width="104dp"
                        android:layout_height="80dp"
                        android:contentDescription="@string/dialog_image_description"
                        android:scaleType="centerInside" />

                    <TextView
                        android:id="@+id/image_source_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:textColor="@color/keyboard_icon_color"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/audio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="4dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/button_record"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/gemma_audio_start_recording" />

                <Button
                    android:id="@+id/button_stop_recording"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:enabled="false"
                    android:text="@string/gemma_audio_stop_recording" />
            </LinearLayout>

            <TextView
                android:id="@+id/media_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:maxLines="2"
                android:minHeight="28dp"
                android:text="@string/gemma_media_not_selected"
                android:textColor="@color/keyboard_icon_color"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/action_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="4dp">

                <TextView
                    android:id="@+id/action_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="4dp"
                    android:text="@string/gemma_image_action_selector_title"
                    android:textColor="@color/keyboard_icon_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Spinner
                        android:id="@+id/spinner_action"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/gemma_action_spinner_background"
                        android:contentDescription="@string/gemma_choose_action"
                        android:popupBackground="@color/keyboard_bg" />

                    <Button
                        android:id="@+id/button_run"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:enabled="false"
                        android:minHeight="0dp"
                        android:text="@string/gemma_run_action"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/empty_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/gemma_no_media_actions"
                android:textColor="@color/keyboard_icon_color"
                android:visibility="gone" />

            <TextView
                android:id="@+id/error_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="3"
                android:padding="4dp"
                android:textColor="@android:color/holo_red_dark"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/progress_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="8dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="36dp"
                    android:layout_height="36dp" />

                <Button
                    android:id="@+id/button_cancel_run"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:text="@string/gemma_cancel_processing" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/result_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/result_candidates"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/result_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/keyboard_bg"
                    android:maxHeight="120dp"
                    android:minHeight="64dp"
                    android:padding="8dp"
                    android:scrollbars="vertical"
                    android:textColor="@color/keyboard_icon_color"
                    android:textIsSelectable="true" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/button_insert_result"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/gemma_insert_result" />

                    <Button
                        android:id="@+id/button_copy_result"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text="@string/gemma_copy_result" />

                    <Button
                        android:id="@+id/button_retry"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text="@string/gemma_try_again" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
