<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:minHeight="56dp"
    android:padding="16dp">

    <TextView
        android:id="@+id/text_candidate_order_rank"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBody1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="1" />

    <TextView
        android:id="@+id/text_candidate_order_candidate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:textAppearance="?attr/textAppearanceListItem"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/image_candidate_order_drag_handle"
        app:layout_constraintStart_toEndOf="@id/text_candidate_order_rank"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="手動" />

    <ImageView
        android:id="@+id/image_candidate_order_drag_handle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@string/candidate_order_override_drag_handle_description"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_drag_handle" />
</androidx.constraintlayout.widget.ConstraintLayout>
