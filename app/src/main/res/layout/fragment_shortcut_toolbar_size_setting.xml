<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".setting_activity.ui.shortcut_toolbar_size.ShortcutToolbarSizeSettingFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="@string/shortcut_toolbar_size_title"
        app:titleCentered="false" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/description_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shortcut_toolbar_size_description"
                android:textAppearance="?attr/textAppearanceBodyMedium" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/integrated_note_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/shortcut_toolbar_size_integrated_note"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?android:attr/textColorSecondary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/preview_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/shortcut_toolbar_size_preview"
                android:textAppearance="?attr/textAppearanceTitleMedium" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/shortcut_toolbar_preview_container"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@color/keyboard_bg"
                    android:gravity="center_vertical"
                    android:minWidth="320dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp" />
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/toolbar_height_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/toolbar_height_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/shortcut_toolbar_height_title"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/toolbar_height_input_layout"
                        android:layout_width="112dp"
                        android:layout_height="wrap_content"
                        app:suffixText="dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/toolbar_height_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1"
                            android:selectAllOnFocus="true" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/toolbar_height_seek_bar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/icon_size_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/icon_size_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/shortcut_toolbar_icon_size_title"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/icon_size_input_layout"
                        android:layout_width="112dp"
                        android:layout_height="wrap_content"
                        app:suffixText="dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/icon_size_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1"
                            android:selectAllOnFocus="true" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/icon_size_seek_bar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reset_button"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/shortcut_toolbar_size_reset" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
