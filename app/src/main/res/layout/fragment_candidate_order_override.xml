<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".candidate_order.ui.CandidateOrderOverrideFragment">

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/edit_text_candidate_order_reading"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/candidate_order_override_reading_hint"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:singleLine="true"
        app:layout_constraintEnd_toStartOf="@id/button_fetch_candidate_order_candidates"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_fetch_candidate_order_candidates"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/candidate_order_override_fetch_candidates"
        app:layout_constraintBottom_toBottomOf="@id/edit_text_candidate_order_reading"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/edit_text_candidate_order_reading" />

    <ProgressBar
        android:id="@+id/progress_candidate_order"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/button_save_candidate_order"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edit_text_candidate_order_reading"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/text_candidate_order_empty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/candidate_order_override_empty"
        android:textAppearance="?attr/textAppearanceBody1"
        app:layout_constraintBottom_toTopOf="@id/button_save_candidate_order"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edit_text_candidate_order_reading" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_candidate_order"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/button_save_candidate_order"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edit_text_candidate_order_reading"
        tools:itemCount="3"
        tools:listitem="@layout/list_item_candidate_order" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_save_candidate_order"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"
        android:enabled="false"
        android:text="@string/candidate_order_override_save"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/button_delete_candidate_order"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_delete_candidate_order"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:enabled="false"
        android:text="@string/delete_key"
        app:layout_constraintBottom_toBottomOf="@id/button_save_candidate_order"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/button_save_candidate_order"
        app:layout_constraintTop_toTopOf="@id/button_save_candidate_order" />
</androidx.constraintlayout.widget.ConstraintLayout>
