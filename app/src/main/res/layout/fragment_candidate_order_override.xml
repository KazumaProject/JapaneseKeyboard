<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".candidate_order.ui.CandidateOrderOverrideFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/edit_text_candidate_order_reading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/candidate_order_override_reading_hint"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:singleLine="true" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_fetch_candidate_order_candidates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/candidate_order_override_fetch_candidates" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_candidate_order"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/text_candidate_order_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/candidate_order_override_empty"
            android:textAppearance="?attr/textAppearanceBody1" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_candidate_order"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            tools:itemCount="3"
            tools:listitem="@layout/list_item_candidate_order" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_save_candidate_order"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="@string/candidate_order_override_save" />

        <TextView
            android:id="@+id/text_saved_candidate_order_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/candidate_order_override_saved_list_title"
            android:textAppearance="?attr/textAppearanceListItem"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_saved_candidate_order"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            tools:itemCount="2"
            tools:listitem="@layout/list_item_saved_candidate_order" />

        <TextView
            android:id="@+id/text_saved_candidate_order_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/candidate_order_override_saved_list_empty"
            android:textAppearance="?attr/textAppearanceBody1" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_delete_all_saved_candidate_order"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="@string/candidate_order_override_delete_all" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
