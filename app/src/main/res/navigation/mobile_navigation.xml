<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_setting">

    <fragment
        android:id="@+id/navigation_setting"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.setting.SettingMainFragment"
        android:label="@string/setting_fragment_title"
        tools:layout="@layout/fragment_setting_main">
        <action
            android:id="@+id/action_navigation_dashboard_to_openSourceFragment"
            app:destination="@id/openSourceFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_dictionaryLearnFragment"
            app:destination="@id/navigation_learn_dictionary" />
        <action
            android:id="@+id/action_navigation_setting_to_keyboardSettingFragment"
            app:destination="@id/keyboardSettingFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_keyboardSelectionFragment"
            app:destination="@id/keyboardSelectionFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_clipboardHistoryFragment"
            app:destination="@id/clipboardHistoryFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_romajiMapFragment"
            app:destination="@id/romajiMapFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_ngWordFragment"
            app:destination="@id/ngWordFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_keyCandidateLetterSizeFragment"
            app:destination="@id/keyCandidateLetterSizeFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_candidateViewHeightSettingFragment"
            app:destination="@id/candidateViewHeightSettingFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_keyboardSizeLandscapeFragment"
            app:destination="@id/keyboardSizeLandscapeFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_candidateHeightLandscapeSettingFragment"
            app:destination="@id/candidateHeightLandscapeSettingFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_candidateTabOrderFragment"
            app:destination="@id/candidateTabOrderFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_enableKeyboardFragment"
            app:destination="@id/enableKeyboardFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_shortcutSettingFragment"
            app:destination="@id/shortcutSettingFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_qwertyMarginSettingFragment"
            app:destination="@id/qwertyMarginSettingFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_qwertyNumberKeyFlickSettingFragment"
            app:destination="@id/qwertyNumberKeyFlickSettingFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_keyboardThemeFragment"
            app:destination="@id/keyboardThemeFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_tenKeyCandidateLetterSizeFragment"
            app:destination="@id/tenKeyCandidateLetterSizeFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_circularFlickSettingsFragment"
            app:destination="@id/circularFlickSettingsFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_flickKeyboardSizeSettingsFragment"
            app:destination="@id/flickKeyboardSizeSettingsFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_systemUserDictionaryBuilderFragment"
            app:destination="@id/systemUserDictionaryBuilderFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_ngramRuleFragment"
            app:destination="@id/ngramRuleFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_gemmaPromptTemplateFragment"
            app:destination="@id/gemmaPromptTemplateFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_deleteKeyFlickTargetsFragment"
            app:destination="@id/deleteKeyFlickTargetsFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_cursorMoveTargetPairsFragment"
            app:destination="@id/cursorMoveTargetPairsFragment" />
        <action
            android:id="@+id/action_navigation_setting_to_physicalKeyboardShortcutListFragment"
            app:destination="@id/physicalKeyboardShortcutListFragment" />
    </fragment>

    <fragment
        android:id="@+id/openSourceFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.opensource.OpenSourceFragment"
        android:label="@string/open_source_fragment_label"
        tools:layout="@layout/fragment_open_source" />
    <fragment
        android:id="@+id/navigation_learn_dictionary"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.dictionary_learn.DictionaryLearnFragment"
        android:label="@string/learn_dictionary_fragment_title" />
    <fragment
        android:id="@+id/keyboardSettingFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.keyboard_size_setting.KeyboardSettingFragment"
        android:label="@string/keyboard_size_setting_fragment_title"
        tools:layout="@layout/fragment_keyboard_setting" />
    <fragment
        android:id="@+id/keyboardSelectionFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.keyboard_selection.KeyboardSelectionFragment"
        android:label="@string/keyboard_selection_fragment_title"
        tools:layout="@layout/fragment_keyboard_selection">
        <action
            android:id="@+id/action_keyboardSelectionFragment_to_keyboardListFragment"
            app:destination="@id/keyboardListFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_user_dictionary"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.user_dictionary.UserDictionaryFragment"
        android:label="@string/user_dictionary_title"
        tools:layout="@layout/fragment_user_dictionary" />
    <fragment
        android:id="@+id/keyboardEditorFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.custom_keyboard.ui.KeyboardEditorFragment"
        android:label="キーボードの編集">
        <argument
            android:name="layoutId"
            android:defaultValue="-1L"
            app:argType="long" />
        <action
            android:id="@+id/action_keyboardEditorFragment_to_keyEditorFragment"
            app:destination="@id/keyEditorFragment" />
    </fragment>
    <fragment
        android:id="@+id/keyEditorFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.custom_keyboard.ui.KeyEditorFragment"
        android:label="@string/key_editor_fragment_label" />
    <fragment
        android:id="@+id/keyboardListFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.custom_keyboard.ui.KeyboardListFragment"
        android:label="@string/custom_layout_fragment_title">
        <action
            android:id="@+id/action_keyboardListFragment_to_keyboardEditorFragment"
            app:destination="@id/keyboardEditorFragment" />
    </fragment>
    <fragment
        android:id="@+id/userTemplateFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.user_template.ui.UserTemplateFragment"
        android:label="@string/user_template_fragment_title" />
    <fragment
        android:id="@+id/clipboardHistoryFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.clipboard_history.ui.ClipboardHistoryFragment"
        android:label="@string/clipboard_fragment_title" />
    <fragment
        android:id="@+id/romajiMapFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.custom_romaji.ui.RomajiMapFragment"
        android:label="@string/romaji_conversion_map_fragment_title">
        <action
            android:id="@+id/action_romajiMapFragment_to_romajiMapDetailFragment"
            app:destination="@id/romajiMapDetailFragment" />
    </fragment>
    <fragment
        android:id="@+id/romajiMapDetailFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.custom_romaji.ui.RomajiMapDetailFragment"
        android:label="@string/romaji_map_fragment_title"
        tools:layout="@layout/fragment_romaji_map_detail">
        <argument
            android:name="mapId"
            app:argType="long" />
    </fragment>
    <fragment
        android:id="@+id/ngWordFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.ng_word.ui.NgWordFragment"
        android:label="@string/ng_word_fragment_title" />
    <fragment
        android:id="@+id/keyCandidateLetterSizeFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.key_candidate_letter_size.KeyCandidateLetterSizeFragment"
        android:label="@string/fragment_key_candidate_letter_size_title"
        tools:layout="@layout/fragment_key_candidate_letter_size" />
    <fragment
        android:id="@+id/candidateViewHeightSettingFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.candidate_view_height_setting.CandidateViewHeightSettingFragment"
        android:label="@string/candidate_view_height_setting_fragment_title"
        tools:layout="@layout/fragment_candidate_view_height_setting" />
    <fragment
        android:id="@+id/keyboardSizeLandscapeFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.keyboard_size_landscape_setting.KeyboardSizeLandscapeFragment"
        android:label="@string/keyboard_size_landscape_title"
        tools:layout="@layout/fragment_keyboardsize_landscape" />
    <fragment
        android:id="@+id/candidateHeightLandscapeSettingFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.candidate_view_height_landscape_setting.CandidateHeightLandscapeSettingFragment"
        android:label="@string/candidate_height_landscape_preference_title"
        tools:layout="@layout/fragment_candidate_height_landscape_setting" />
    <fragment
        android:id="@+id/candidateTabOrderFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.candidate_tab_order.ui.CandidateTabOrderFragment"
        android:label="@string/candidate_tab_order_preference_title" />
    <fragment
        android:id="@+id/enableKeyboardFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.enable_keyboard_setting.EnableKeyboardFragment"
        android:label="fragment_enable_keyboard"
        tools:layout="@layout/fragment_enable_keyboard" />
    <fragment
        android:id="@+id/shortcutSettingFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.short_cut.ui.ShortcutSettingFragment"
        android:label="@string/shortcutsettingfragment" />
    <fragment
        android:id="@+id/qwertyMarginSettingFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.qwerty_button_size.QwertyMarginSettingFragment"
        android:label="@string/qwertymarginsettingfragment" />
    <fragment
        android:id="@+id/qwertyNumberKeyFlickSettingFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.qwerty_number_key_flick.QwertyNumberKeyFlickSettingFragment"
        android:label="QWERTY 数字キーのフリック設定"
        tools:layout="@layout/fragment_qwerty_number_key_flick_setting" />
    <fragment
        android:id="@+id/keyboardThemeFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.keyboard_theme.KeyboardThemeFragment"
        android:label="@string/keyboardthemefragment" />
    <fragment
        android:id="@+id/tenKeyCandidateLetterSizeFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.tenkey_letter_size_setting.TenKeyCandidateLetterSizeFragment"
        android:label="@string/tenkeycandidatelettersizefragment" />
    <fragment
        android:id="@+id/circularFlickSettingsFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.sumire_custom_angle.CircularFlickSettingsFragment"
        android:label="@string/circularflicksettingsfragment" />
    <fragment
        android:id="@+id/flickKeyboardSizeSettingsFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.setting_activity.ui.sumire_custom_key_setting.FlickKeyboardSizeSettingsFragment"
        android:label="@string/flickKeyboardSizeSettingsFragment_title" />
    <fragment
        android:id="@+id/systemUserDictionaryBuilderFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.system_user_dictionary.ui.SystemUserDictionaryBuilderFragment"
        android:label=""
        tools:layout="@layout/fragment_system_user_dictionary_builder" />
    <fragment
        android:id="@+id/ngramRuleFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.ngram_rule.ui.NgramRuleFragment"
        android:label="@string/n_gram_rule_preference_title"
        tools:layout="@layout/fragment_ngram_rule" />
    <fragment
        android:id="@+id/gemmaPromptTemplateFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.gemma.ui.GemmaPromptTemplateFragment"
        android:label="@string/gemma_prompt_template_fragment_title"
        tools:layout="@layout/fragment_gemma_prompt_template" />
    <fragment
        android:id="@+id/deleteKeyFlickTargetsFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.delete_key_flick.ui.DeleteKeyFlickTargetsFragment"
        android:label="@string/delete_key_flick_targets_fragment_title"
        tools:layout="@layout/fragment_delete_key_flick_targets" />
    <fragment
        android:id="@+id/cursorMoveTargetPairsFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.cursor_move_targets.ui.CursorMoveTargetPairsFragment"
        android:label="@string/cursor_move_target_pairs_fragment_title"
        tools:layout="@layout/fragment_cursor_move_target_pairs" />
    <fragment
        android:id="@+id/physicalKeyboardShortcutListFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.physical_keyboard.shortcut.ui.PhysicalKeyboardShortcutListFragment"
        android:label="@string/physical_keyboard_shortcut_list_title">
        <action
            android:id="@+id/action_physicalKeyboardShortcutListFragment_to_physicalKeyboardShortcutEditFragment"
            app:destination="@id/physicalKeyboardShortcutEditFragment" />
    </fragment>
    <fragment
        android:id="@+id/physicalKeyboardShortcutEditFragment"
        android:name="com.kazumaproject.markdownhelperkeyboard.physical_keyboard.shortcut.ui.PhysicalKeyboardShortcutEditFragment"
        android:label="@string/physical_keyboard_shortcut_edit_title">
        <argument
            android:name="shortcutId"
            android:defaultValue="0L"
            app:argType="long" />
    </fragment>

</navigation>
